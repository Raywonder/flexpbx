{
  "name": "flexpbx-desktop",
  "version": "1.0.0",
  "description": "FlexPBX Unified Desktop Client - Complete PBX Management Suite",
  "main": "src/main/AdminMain.js",
  "scripts": {
    "start": "electron .",
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "dist": "npm run build",
    "test": "echo \"No tests specified\" && exit 0",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rm -rf dist build node_modules/.cache",
    "ultimate-build": "node ULTIMATE-BUILD.js",
    "test:full": "jest --coverage",
    "lint": "eslint src/",
    "security-audit": "npm audit --audit-level=moderate",
    "build:all": "electron-builder --mac --win --linux",
    "build:portable": "node portable-config.js"
  },
  "keywords": [
    "pbx",
    "voip",
    "electron",
    "desktop",
    "accessibility",
    "macos"
  ],
  "author": "FlexPBX Team",
  "license": "MIT",
  "devDependencies": {
    "chokidar": "^3.5.3",
    "electron": "^25.3.1",
    "electron-builder": "^24.6.3",
    "electron-notarize": "^1.2.2",
    "eslint": "^8.45.0",
    "jest": "^29.6.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "basic-ftp": "^5.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dockerode": "^4.0.0",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "googleapis": "^161.0.0",
    "helmet": "^7.1.0",
    "highlight.js": "^11.8.0",
    "marked": "^5.1.1",
    "node-forge": "^1.3.1",
    "node-ssh": "^13.1.0",
    "scp2": "^0.2.2",
    "ssh2": "^1.14.0",
    "sudo-prompt": "^9.2.1",
    "tar": "^6.2.0",
    "uuid": "^9.0.0",
    "webdav": "^5.3.0",
    "which": "^4.0.0",
    "ws": "^8.14.2"
  },
  "build": {
    "appId": "com.flexpbx.desktop",
    "productName": "FlexPBX Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "resources/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "FlexPBX Team",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
