{
  "name": "FlexPBX Enterprise",
  "version": "1.0.0",
  "type": "enterprise",
  "features": [
    "multi-tenant",
    "clustering",
    "ha-failover",
    "advanced-analytics"
  ],
  "requirements": {
    "minRAM": "8GB",
    "minCPU": "4 cores",
    "minStorage": "100GB",
    "database": "PostgreSQL 13+",
    "redis": "Required",
