    "minCPU": "2 cores",
    "minStorage": "50GB",
    "database": "PostgreSQL or MySQL",
    "redis": "Recommended",
    "clustering": "Limited"
  },
  "modules": [
    "core",
    "pbx-engine",
    "sip-trunk",
